# docker/caddy/Caddyfile
{
    auto_https off
}

:80 {
    root * /var/www/html/public

    encode gzip

    file_server {
        precompressed gzip
    }

    @static {
        path *.css *.js *.ico *.gif *.jpg *.jpeg *.png *.svg *.woff *.woff2
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    php_fastcgi app:9000
}
